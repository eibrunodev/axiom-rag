# ── Required for ingest and query ─────────────────────────────────────────────
GEMINI_API_KEY=your-key-here

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# Store-only commands (list, delete, stats) do not require GEMINI_API_KEY.

RAG_CHROMA_PATH=~/.rag/chroma          # ChromaDB persistence directory
RAG_COLLECTION=documents               # collection name within ChromaDB
RAG_CHUNK_SIZE=512                     # words per chunk (~680 tokens for English prose)
RAG_CHUNK_OVERLAP=64                   # word overlap between consecutive chunks
RAG_TOP_K=5                            # max chunks retrieved per query
RAG_SCORE_THRESHOLD=0.4               # min cosine similarity (0–1); tune empirically
RAG_EMBEDDING_MODEL=models/text-embedding-004
RAG_GENERATION_MODEL=gemini-2.5-flash

# ── REST API authentication ───────────────────────────────────────────────────
# If set, all API requests must include: Authorization: Bearer <token>
# Leave unset for local use only.
# RAG_API_TOKEN=
